# Godot
# stick-world/docs 是指向 ../../docs 的本地 symlink（core.symlinks=false 无法追踪）
stick-world/docs
.import/
export/*
!export/.gitkeep
*.translation
**/.godot/
.godot/

# Godot 插件（第三方 addons，通过自更新/包管理器维护）
addons/
!addons/.gitkeep

# Godot 4 GDExtension 构建输出
*.so
*.dll
*.dylib
gdextension_crash_on_quit.txt

# AI 助手记忆 / 本地状态
.workbuddy/
.mcp/
.codebuddy/

# AI 工具本地运行时产物
**/__pycache__/
**/*.pyc
tools/godot_ai_repo/.venv/
tools/godot_ai_repo/venv/
tools/vector_db/chroma_db/
tools/volc_image_gen/output/
tools/volc_image_gen/.env
stick-world/assets/_raw/

# 世界生成工具：.npy 是大数据文件（高度场/mask，256MB+），不提交，只提交 PNG 预览
tools/worldgen/output/**/*.npy
.tmp/

# 调试 / 日志
debug.log
*.log

# IDE
.vs/
.vscode/*
!.vscode/settings.json
*.swp
*.swo
*.sublime-workspace
.idea/

# 编辑器缓存（Godot 自动生成文件）
*.uid
*.ctex
*.md5
*.res-folding-*.cfg

# Godot 导出 / 构建产物
build/
dist/
*.exe
*.pck
*.zip

# 测试报告
test-reports/
test-results/
coverage/
*.xml

# OS
.DS_
# 第三方开源库（本地参考用，不入 Git）
external/
!external/.gitkeep
# 保留已存在的 swl_extracted 特例（已在上一行 external/ 中被忽略，这里仅作记录）

node_modules/.package-lock.json
node_modules/sticknodes-js/LICENSE
node_modules/sticknodes-js/package.json
node_modules/sticknodes-js/README.docs.md
node_modules/sticknodes-js/README.md
node_modules/sticknodes-js/sticknodes_js_bg.js
node_modules/sticknodes-js/sticknodes_js_bg.wasm
node_modules/sticknodes-js/sticknodes_js_bg.wasm.d.ts
node_modules/sticknodes-js/sticknodes_js_nodejs_bg.js
node_modules/sticknodes-js/sticknodes_js_nodejs_bg.wasm
node_modules/sticknodes-js/sticknodes_js_nodejs.js
node_modules/sticknodes-js/sticknodes_js_web_bg.wasm
node_modules/sticknodes-js/sticknodes_js_web.js
node_modules/sticknodes-js/sticknodes_js.d.ts
node_modules/sticknodes-js/sticknodes_js.js
