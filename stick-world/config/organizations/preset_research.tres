[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://config/balance/balance_resource.gd" id="1"]

[resource]
script = ExtResource("1")
resource_name = "preset_research"
_meta = {
	"resource_name": "preset_research",
	"version": "0.1.0",
	"description": "科研机构预设模板：科学院→研究所→研究室→课题组",
	"category": "organization_preset",
	"tag": "科研"
}

variables = {
	# ── 编制层级深度 ──
	"hierarchy": ["academy", "institute", "laboratory", "research_group"],

	# ── 科学院（L5） ──
	"academy": {
		"label": "科学院",
		"level": 5,
		"personnel_template": {
			"president": null,
			"academicians": "[PLACEHOLDER]",
			"administrative_staff": "[PLACEHOLDER]"
		},
		"default_focus": "基础理论研究",
		"autonomy_level": "高",
		"supply_priority": "高",
		"subordinate_count": "[PLACEHOLDER]"
	},

	# ── 研究所（L4） ──
	"institute": {
		"label": "研究所",
		"level": 4,
		"personnel_template": {
			"director": null,
			"senior_researchers": "[PLACEHOLDER]",
			"junior_researchers": "[PLACEHOLDER]",
			"technicians": "[PLACEHOLDER]"
		},
		"default_focus": "应用研究",
		"autonomy_level": "中",
		"supply_priority": "中",
		"subordinate_count": "[PLACEHOLDER]"
	},

	# ── 研究室（L3） ──
	"laboratory": {
		"label": "研究室",
		"level": 3,
		"personnel_template": {
			"lead_researcher": null,
			"researchers": "[PLACEHOLDER]",
			"assistants": "[PLACEHOLDER]"
		},
		"default_focus": "实验验证",
		"autonomy_level": "中",
		"supply_priority": "中",
		"subordinate_count": "[PLACEHOLDER]"
	},

	# ── 课题组（L2） ──
	"research_group": {
		"label": "课题组",
		"level": 2,
		"personnel_template": {
			"group_leader": null,
			"members": "[PLACEHOLDER]"
		},
		"default_focus": "课题攻关",
		"autonomy_level": "低",
		"supply_priority": "低",
		"subordinate_count": 0
	},

	# ── 调优参数 ──
	"tuning": {
		"optimal_span_of_control": "[PLACEHOLDER]",
		"depth_penalty_per_level": "[PLACEHOLDER]",
		"tag_match_bonus": "[PLACEHOLDER]",
		"reorganization_transition_days": "[PLACEHOLDER]",
		"ai_decision_accuracy": "[PLACEHOLDER]"
	}
}
