[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://config/balance/balance_resource.gd" id="1"]

[resource]
script = ExtResource("1")
resource_name = "preset_military"
_meta = {
	"resource_name": "preset_military",
	"version": "0.1.0",
	"description": "军事编制预设模板：师→团→连→排的默认配置",
	"category": "organization_preset",
	"tag": "军事"
}

variables = {
	# ── 编制层级深度 ──
	"hierarchy": ["division", "regiment", "company", "platoon"],

	# ── 师（L4） ──
	"division": {
		"label": "师",
		"level": 4,
		"personnel_template": {
			"commander": null,
			"staff_officers": "[PLACEHOLDER]",
			"total_strength": "[PLACEHOLDER]"
		},
		"equipment_template": {
			"standard_weapons": "[PLACEHOLDER]",
			"standard_armor": "[PLACEHOLDER]",
			"logistics_vehicles": "[PLACEHOLDER]"
		},
		"default_tactics": "主动进攻",
		"autonomy_level": "中",
		"supply_priority": "高",
		"subordinate_count": "[PLACEHOLDER]"
	},

	# ── 团（L3） ──
	"regiment": {
		"label": "团",
		"level": 3,
		"personnel_template": {
			"commander": null,
			"staff_officers": "[PLACEHOLDER]",
			"total_strength": "[PLACEHOLDER]"
		},
		"equipment_template": {
			"standard_weapons": "[PLACEHOLDER]",
			"standard_armor": "[PLACEHOLDER]"
		},
		"default_tactics": "主动进攻",
		"autonomy_level": "中",
		"supply_priority": "中",
		"subordinate_count": "[PLACEHOLDER]"
	},

	# ── 连（L2） ──
	"company": {
		"label": "连",
