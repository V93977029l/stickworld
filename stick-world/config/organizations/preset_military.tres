		"personnel_template": {
			"commander": null,
			"total_strength": "[PLACEHOLDER]"
		},
		"equipment_template": {
			"standard_weapons": "[PLACEHOLDER]",
			"standard_armor": "[PLACEHOLDER]"
		},
		"default_tactics": "坚守阵地",
		"autonomy_level": "低",
		"supply_priority": "中",
		"subordinate_count": "[PLACEHOLDER]"
