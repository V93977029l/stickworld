[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://config/balance/balance_resource.gd" id="1"]

[resource]
script = ExtResource("1")
resource_name = "stickman_base_stats"
_meta = {
	"resource_name": "stickman_base_stats",
	"version": "0.1.0",
	"description": "火柴人基础属性模板",
	"category": "unit_template"
}

variables = {
	# ── 战斗属性（来自 combat-variables.md 单位基础属性表） ──
	"base_hp": "[PLACEHOLDER]",
	"base_movement_speed": "[PLACEHOLDER]",
	"base_attack": "[PLACEHOLDER]",
	"base_attack_speed": "[PLACEHOLDER]",
	"base_attack_range": "[PLACEHOLDER]",
	"base_defense": "[PLACEHOLDER]",

	# ── 经济属性（来自 variables.md 战斗表） ──
	"base_morale": 100,
	"morale_break_threshold": "[PLACEHOLDER]",

	# ── 标签 ──
	"tags": ["humanoid", "biological", "basic_unit"]
}
