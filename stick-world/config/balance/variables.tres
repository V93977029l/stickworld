[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://config/balance/balance_resource.gd" id="1"]

[resource]
script = ExtResource("1")
resource_name = "global_balance_variables"
_meta = {
	"resource_name": "global_balance_variables",
	"version": "0.1.0",
	"description": "全局平衡变量，从 variables.md 经济变量表提取",
	"category": "balance_variables"
}

variables = {
	# ── 一、基础资源（初始值） ──
	"initial_food": "[PLACEHOLDER]",
	"initial_wood": "[PLACEHOLDER]",
	"initial_stone": "[PLACEHOLDER]",
	"initial_metal_ore": "[PLACEHOLDER]",
	"initial_black_bitumen": "[PLACEHOLDER]",
	"food_consumption_per_stickman_per_day": "[PLACEHOLDER]",
	"soldier_food_consumption_per_day": "[PLACEHOLDER]",

	# ── 二、生产效率 ──
	"farmer_food_output_per_day": "[PLACEHOLDER]",
	"miner_ore_output_per_day": "[PLACEHOLDER]",
	"lumberjack_wood_output_per_day": "[PLACEHOLDER]",
	"builder_construction_speed": "[PLACEHOLDER]",
	"researcher_research_points_per_month": "[PLACEHOLDER]",

	# ── 三、市场价格 ──
	"market": {
		"food_base_price": "[PLACEHOLDER]",
		"food_price_fluctuation": "[PLACEHOLDER]",
		"wood_base_price": "[PLACEHOLDER]",
		"wood_price_fluctuation": "[PLACEHOLDER]",
		"stone_base_price": "[PLACEHOLDER]",
		"stone_price_fluctuation": "[PLACEHOLDER]",
		"metal_ore_base_price": "[PLACEHOLDER]",
		"metal_ore_price_fluctuation": "[PLACEHOLDER]",
		"black_bitumen_base_price": "[PLACEHOLDER]",
		"black_bitumen_price_fluctuation": "[PLACEHOLDER]",
		"weapon_base_price": "[PLACEHOLDER]",
		"armor_base_price": "[PLACEHOLDER]",
		"spell_scroll_base_price": "[PLACEHOLDER]"
	},

	# ── 四、经济制度参数 ──
	"base_tax_rate": "[PLACEHOLDER]",
	"inflation_warning_threshold": "[PLACEHOLDER]",
	"market_response_delay_days": "[PLACEHOLDER]",
	"corruption_natural_rate": "[PLACEHOLDER]",
	"transport_cost_per_km": "[PLACEHOLDER]",

	# ── 五、人口 ──
	"initial_followers": 0,
	"natural_growth_rate": "[PLACEHOLDER]",
	"summon_bitumen_cost_per_stickman": "[PLACEHOLDER]",
	"happiness_unrest_threshold": "[PLACEHOLDER]",

	# ── 六、科技 ──
	"base_research_speed_per_researcher_per_month": "[PLACEHOLDER]",
	"bitumen_consumption_per_researcher_per_month": "[PLACEHOLDER]",
	"education_roi_years": "[PLACEHOLDER]",
	"technology_diffusion_rate": "[PLACEHOLDER]",

	# ── 七、扩张与管理 ──
	"region_control_gain_rate": "[PLACEHOLDER]",
	"aggressive_expansion_decay": "[PLACEHOLDER]",
	"overextension_threshold": "[PLACEHOLDER]",
	"management_cost_exponent": "[PLACEHOLDER]",
	"coalition_ae_threshold": "[PLACEHOLDER]",

	# ── 八、战斗（来自 variables.md 战斗表） ──
	"combat": {
		"base_hp": "[PLACEHOLDER]",
		"base_attack": "[PLACEHOLDER]",
		"morale_break_threshold": "[PLACEHOLDER]",
		"command_delay_per_layer": "[PLACEHOLDER]",
