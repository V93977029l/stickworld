# 存档文件扩展名
const SAVE_EXTENSION: String = "sav"

# 最大存档槽位数
const MAX_SAVE_SLOTS: int = 10

# 最小支持分辨率（宽 × 高）
const MIN_RESOLUTION: Vector2i = Vector2i(800, 600)