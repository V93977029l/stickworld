root = true

[*]
indent_style = space
insert_final_newline = true
charset = utf-8
end_of_line = lf

[*.{c,h,cpp,hpp,cc,hh,cxx,hxx}]
indent_style = space
indent_size = 4

[*.{py,SConstruct,SConscript}]
indent_style = space
indent_size = 4

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{gd,tres,tscn,godot}]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = space
indent_size = 4

[*.bat]
end_of_line = crlf

[*.makefile]
indent_style = tab
